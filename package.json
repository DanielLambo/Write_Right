{
  "name": "learn-and-write",
  "version": "1.0.0",
  "description": "Learning-While-Writing Assistant - Desktop app for students",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:backend": "tsx watch src/backend/server.ts",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 http://localhost:3051 && cross-env NODE_ENV=development electron .",
    "build": "tsc && npm run build:renderer",
    "build:renderer": "vite build",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "summary": "tsx scripts/printSessionSummary.ts"
  },
  "keywords": [
    "electron",
    "education",
    "writing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^4.1.4",
    "wait-on": "^7.2.0"
  }
}
